generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model TechStack {
  id Int @id @default(autoincrement())
  name String? @default("")
  postId Int
  post Post @relation(fields: [postId], references: [id])
}

model Tags {
  id Int @id @default(autoincrement())
  name String? @default("")
  postId Int
  post Post @relation(fields: [postId], references: [id])
}

model PostComment {
  id Int @id @default(autoincrement())
  text String
  createdAt DateTime @default(now())
  postId Int
  post Post @relation(fields: [postId], references: [id])
  authorId Int
  author User @relation(fields: [authorId], references: [id])
}

model CodeSnippet {
  id Int @id @default(autoincrement())
  language String? 
  code String?
  postId Int @unique
  post Post @relation(fields: [postId], references: [id])
}

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  cards Post[]
  comments PostComment[]
}

model Post {
  id Int @id @default(autoincrement())
  authorId Int
  author User @relation(fields: [authorId], references: [id])
  content String
  tags Tags[]
  techStack TechStack[]
  likes Int
  comments PostComment[]
  reposts Int
  bookmarks Int
  createdAt DateTime @default(now())
  isLiked Boolean
  isBookmarked Boolean
  isReposted Boolean
  image String?
  codeSnippet CodeSnippet?
}